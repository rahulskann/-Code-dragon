# Code Dragon — server-side API keys (used by the Vercel functions in /api).
# In production set these in Vercel → Settings → Environment Variables (mark Sensitive).
# For local testing with `vercel dev`, copy this file to `.env` and fill it in.

# Google AI Studio key (enables AI Mode + Résumé Mode). https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=

# ElevenLabs key (optional — enables character voices). https://elevenlabs.io
ELEVEN_API_KEY=
